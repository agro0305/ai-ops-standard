{
  "plan_id": "example-safe-write",
  "intent": "Create a demonstration file without changing an existing service",
  "preconditions": [
    {
      "type": "writable",
      "path": "/tmp"
    }
  ],
  "actions": [
    {
      "type": "mkdir",
      "path": "/tmp/aiops-example"
    },
    {
      "type": "write_file",
      "path": "/tmp/aiops-example/status.txt",
      "content": "AI-OPS example\n"
    }
  ],
  "verification": [
    {
      "type": "exists",
      "path": "/tmp/aiops-example/status.txt"
    },
    {
      "type": "file_contains",
      "path": "/tmp/aiops-example/status.txt",
      "text": "AI-OPS example"
    }
  ]
}
