{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-ops-standard.org/schemas/runtime-health.schema.json",
  "title": "AI-OPS Runtime Health Report",
  "type": "object",
  "required": [
    "schema_version", "generated_at", "project_root", "dashboard_url",
    "require_services", "success", "summary", "checks"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "generated_at": {"type": "string", "format": "date-time"},
    "project_root": {"type": "string"},
    "dashboard_url": {"type": "string"},
    "require_services": {"type": "boolean"},
    "success": {"type": "boolean"},
    "summary": {
      "type": "object",
      "required": ["pass", "warn", "fail"],
      "properties": {
        "pass": {"type": "integer", "minimum": 0},
        "warn": {"type": "integer", "minimum": 0},
        "fail": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status", "message"],
        "properties": {
          "name": {"type": "string"},
          "status": {"enum": ["pass", "warn", "fail"]},
          "message": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
