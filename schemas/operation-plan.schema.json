{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-ops-standard.org/schemas/operation-plan.schema.json",
  "title": "AI-OPS Operation Plan",
  "type": "object",
  "required": ["schema_version", "plan_id", "created_at", "intent", "risk", "actions", "backup", "verification", "rollback", "status"],
  "properties": {
    "schema_version": {"type": "string"},
    "plan_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "intent": {"type": "string"},
    "discovery_report": {"type": "string"},
    "discovery_host": {"type": "object"},
    "risk": {
      "type": "object",
      "required": ["level", "approval_required"],
      "properties": {
        "level": {"enum": ["low", "medium", "high", "critical"]},
        "approval_required": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "preconditions": {"type": "array", "items": {"type": "string"}},
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {"enum": ["mkdir", "write_file", "copy_file", "delete", "command"]},
          "path": {"type": "string"},
          "source": {"type": "string"},
          "content": {"type": "string"},
          "argv": {"type": "array", "items": {"type": "string"}, "minItems": 1},
          "timeout": {"type": "integer", "minimum": 1},
          "service_restart": {"type": "boolean"},
          "production": {"type": "boolean"},
          "safety_critical": {"type": "boolean"}
        },
        "additionalProperties": true
      }
    },
    "backup": {
      "type": "object",
      "required": ["required", "targets"],
      "properties": {
        "required": {"type": "boolean"},
        "targets": {"type": "array", "items": {"type": "string"}}
      }
    },
    "verification": {"type": "array", "items": {"type": "object"}},
    "rollback": {"type": "object"},
    "status": {"enum": ["ready", "awaiting-approval"]}
  },
  "additionalProperties": true
}
